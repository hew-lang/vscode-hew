// Machine declarations and duration literals

machine TrafficLight {
    // Input-event vocabulary (v0.5 events {} block)
    events {
        Timer;
        Emergency { reason: string; }
    }

    state Red;
    state Green;
    state Yellow;

    // v0.5 routing arrow is =>  (not ->)
    on Timer: Red => Green {
        Green
    }

    on Timer: Green => Yellow {
        Yellow
    }

    on Timer: Yellow => Red {
        Red
    }

    on Emergency: Red => Red reenter {
        Red
    }

    default { state }
}

// Duration literals in various forms
fn duration_demo() {
    let ns_val = 100ns;
    let us_val = 50us;
    let ms_val = 200ms;
    let s_val = 5s;
    let m_val = 2m;
    let h_val = 1h;
}

// Supervisor with child specs
supervisor ServiceTree {
    strategy: one_for_one;
    budget {
        intensity: 5;
        within: 60s;
    }

    child counter: Counter(100);
    child debug_log: Logger(1);
    child error_log: Logger(3);
}
