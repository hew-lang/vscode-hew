// SYNTAX TEST "source.hew"

// -- #[wire] declarations --

    #[wire]
//  ^^ punctuation.definition.attribute.begin.hew
//    ^^^^ entity.name.function.attribute.hew
//        ^ punctuation.definition.attribute.end.hew
type UserCreated {
// <- keyword.declaration.hew
//   ^^^^^^^^^^^ entity.name.type.hew
    id: u64 @1,
//          ^^ constant.numeric.wire-tag.hew
    name: string @2,
//               ^^ constant.numeric.wire-tag.hew
}

// -- Wire keywords --

type WireSchema {
    reserved(5, 6);
//  ^^^^^^^^ keyword.wire.hew
    old_field: string @5 deprecated,
//                    ^^ constant.numeric.wire-tag.hew
//                       ^^^^^^^^^^ keyword.wire.hew
    nickname: string @6 optional,
//                   ^^ constant.numeric.wire-tag.hew
//                      ^^^^^^^^ keyword.wire.hew
    flags: i32 @7 default(0),
//             ^^ constant.numeric.wire-tag.hew
//                ^^^^^^^ keyword.wire.hew
}
