// SYNTAX TEST "source.hew"

// -- Arrow operators --

x -> y
//^^ keyword.operator.arrow.hew

x => y
//^^ keyword.operator.arrow.hew

// -- Range operators --

    x..y
//   ^^ keyword.operator.range.hew

    x..=y
//   ^^^ keyword.operator.range.hew

// -- Comparison operators --

x == y
//^^ keyword.operator.comparison.hew

x != y
//^^ keyword.operator.comparison.hew

x <= y
//^^ keyword.operator.comparison.hew

x >= y
//^^ keyword.operator.comparison.hew

a << b
//^^ keyword.operator.bitwise.shift.hew

a >> b
//^^ keyword.operator.bitwise.shift.hew

// -- Compound assignment --

x += 1
//^^ keyword.operator.assignment.compound.hew

x -= 1
//^^ keyword.operator.assignment.compound.hew

x *= 2
//^^ keyword.operator.assignment.compound.hew

x /= 2
//^^ keyword.operator.assignment.compound.hew

x %= 3
//^^ keyword.operator.assignment.compound.hew

x <<= 2
//^^^ keyword.operator.assignment.compound.hew

x >>= 2
//^^^ keyword.operator.assignment.compound.hew

// -- Assignment --

x = 5
//^ keyword.operator.assignment.hew

// -- Error propagation --

result?
//    ^ keyword.operator.question.hew

// -- Logical operators --

x && y
//^^ keyword.operator.logical.hew

x || y
//^^ keyword.operator.logical.hew

// -- Logical not --

!valid
// <- keyword.operator.not.hew

// -- Bitwise / wrapping operators --

a ^ b
//^ keyword.operator.bitwise.xor.hew

a &+ b
//^^ keyword.operator.wrapping.hew

a &- b
//^^ keyword.operator.wrapping.hew

a &* b
//^^ keyword.operator.wrapping.hew

// -- Removed operators --

a =~ b
//^^ invalid.removed.hew

a !~ b
//^^ invalid.removed.hew

// -- Namespace --

std::io
// ^^ keyword.operator.namespace.hew

// -- At (label / wire marker) --

@outer
// <- entity.name.label.hew
