// SYNTAX TEST "source.hew"

// -- Regular strings --

"hello world"
// <- string.quoted.double.hew

"with escape \n inside"
//           ^^ constant.character.escape.hew

"tab\there"
//  ^^ constant.character.escape.hew

"return\r"
//     ^^ constant.character.escape.hew

"null\0char"
//   ^^ constant.character.escape.hew

"escaped\\backslash"
//      ^^ constant.character.escape.hew

"escaped\"quote"
//      ^^ constant.character.escape.hew

"hex \x41 escape"
//   ^^^^ constant.character.escape.hew

// -- Char literals --

'a'
// <- string.quoted.single.char.hew

'\n'
// <- string.quoted.single.char.hew

// -- Byte string literals --

b"hello"
// <- string.quoted.byte.hew

// -- Raw strings --

r"no escapes \n here"
// <- string.quoted.raw.hew

// -- Interpolated strings --

f"hello {name}"
// <- string.interpolated.hew
//      ^ punctuation.section.interpolation.begin.hew
//           ^ punctuation.section.interpolation.end.hew

f"count: {x + 1}"
// <- string.interpolated.hew
//       ^ punctuation.section.interpolation.begin.hew
//             ^ punctuation.section.interpolation.end.hew

// -- Escaped quotes before AND after an interpolation (grammar.ebnf:385-386) --

f"x \"{a}\" y"
//  ^^ constant.character.escape.hew
//    ^ punctuation.section.interpolation.begin.hew
//      ^ punctuation.section.interpolation.end.hew
//       ^^ constant.character.escape.hew

// -- Regex literal: re"pattern" (grammar.ebnf:390) --

re"\d+abc"
// <- string.regexp.hew
//    ^ string.regexp.hew

